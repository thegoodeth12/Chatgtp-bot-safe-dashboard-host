name: Sync Safe Dashboard

on:
  workflow_dispatch:
  schedule:
    - cron: '0 * * * *'  # Every hour

jobs:
  fetch-private-data:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout this repo
        uses: actions/checkout@v3

      - name: Fetch dashboard data from .github-private
        run: |
          mkdir -p public/data
          curl -H "Authorization: Bearer ${{ secrets.PRIVATE_REPO_ACCESS_TOKEN }}" \
               -H "Accept: application/vnd.github.v3.raw" \
               -o public/data/dashboard-data.json \
               https://api.github.com/repos/Chatgtp-bot/.github-private/contents/dashboard-data.json

      - name: Commit and push updated data
        run: |
          git config user.name "thegoodeth12"
          git config user.email "172343141+thegoodeth12@users.noreply.github.com"
          git add public/data/dashboard-data.json
          git commit -m "Update dashboard data"
          git push
